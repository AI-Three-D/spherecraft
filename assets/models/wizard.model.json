    "SITTING":           { "clip": "Sitting",         "loop": true                   },
    "SLEEPING":          { "clip": "Sleeping",        "loop": true                   },
    "DRINKING":          { "clip": "Drinking",        "loop": true                   },
    "CROUCH_TORCH_WALK": { "clip": "Crouch_torch_1",  "loop": true                   },

    "SKILL":             { "clip": "Attacking",       "loop": false                  },
    "SPELL_CAST":        { "clip": "Spell1",          "loop": false                  },
    "ATTACK_LIGHT":      { "clip": "Punching",        "loop": false                  },
    "ATTACK_HEAVY":      { "clip": "Power_attack",    "loop": false                  }
  }
