    "UNSTEADY_WALK":     { "clip": "Tired_walk",      "loop": true                   },

    "DEAD":              { "clip": "Dying",           "loop": false, "blendIn": 0.08 },
    "EXHAUSTED":         { "clip": "Exhausted",       "loop": false                  },
    "FALLING":           { "clip": "Falling",         "loop": false, "blendIn": 0.05 },
    "FREE_FALLING":      { "clip": "Free_falling",    "loop": true                   },
    "GETTING_UP":        { "clip": "Getting_up",      "loop": false                  },

    "HIT_FROM_FRONT_1":  { "clip": "Hit_from_front1", "loop": false, "blendIn": 0.05 },
